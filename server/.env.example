# Server port (Render/Railway set this automatically, safe to leave default)
PORT=3001

# Comma-separated list of allowed frontend origins (NO trailing slash)
# Example: https://chatrix-app.vercel.app,https://yourdomain.com
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string (leave empty to use in-memory demo storage)
# Get this from https://cloud.mongodb.com after creating a free cluster
MONGODB_URI=

# Random secret string for signing JWT tokens — CHANGE THIS in production
JWT_SECRET=change_this_to_a_long_random_string

NODE_ENV=production
